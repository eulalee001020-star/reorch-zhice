# Application
APP_ENV=development
APP_DEBUG=true
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=reorch
DB_PASSWORD=reorch
DB_NAME=reorch
DB_ECHO=false

# Redis / ARQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_GROUP_ID=reorch

# PoC auth users:
# username:password:user_id:role:api_key:display_name
AUTH_USERS=planner:planner123:planner-1:Planner:planner-key-001:Planner,executor:executor123:executor-1:Shop_Floor_Executor:executor-key-001:Executor,manager:manager123:mgmt-1:Management:mgmt-key-001:Manager,admin:admin123:admin-1:IT_Admin:admin-key-001:Admin

# Customer-system adapters. Leave blank for local PoC mode.
# For Docker Compose sandbox联调, use http://mock-integration:8010.
INTEGRATION_MES_BASE_URL=
INTEGRATION_MES_API_KEY=
INTEGRATION_MES_WRITEBACK_PATH=/api/schedule/writeback
INTEGRATION_MES_PROGRESS_PATH=/api/execution/progress
INTEGRATION_MES_HEALTH_PATH=/health
INTEGRATION_MES_FORMAT=standard

INTEGRATION_ERP_APS_BASE_URL=
INTEGRATION_ERP_APS_API_KEY=
INTEGRATION_ERP_APS_SNAPSHOT_PATH=/api/schedule/snapshot
INTEGRATION_ERP_APS_RESOURCES_PATH=/api/resources
INTEGRATION_ERP_APS_WORK_ORDERS_PATH=/api/work-orders
INTEGRATION_ERP_APS_HEALTH_PATH=/health

INTEGRATION_IOT_BASE_URL=
INTEGRATION_IOT_API_KEY=
INTEGRATION_IOT_EVENTS_PATH=/api/events
INTEGRATION_IOT_HEALTH_PATH=/health
INTEGRATION_REQUEST_TIMEOUT_SECONDS=10

# CSV adapter offline import directory, if used by custom scripts/tests.
INTEGRATION_CSV_DATA_DIR=
